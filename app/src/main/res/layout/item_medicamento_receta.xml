<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:backgroundTint="@color/citas_white"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:backgroundTint="@color/citas_white"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:backgroundTint="@color/citas_white"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvNombreMedicamento"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Amoxicilina 500mg" />

            <TextView
                android:id="@+id/tvFormaFarmaceutica"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#E8EAF6"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="#3F51B5"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Cápsulas" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvDosis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#424242"
                android:textSize="13sp"
                tools:text="Dosis: 1 cada 8 horas" />

            <TextView
                android:id="@+id/tvCantidadTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#757575"
                android:textSize="12sp"
                tools:text="Cant: 21" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDuracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#757575"
            android:textSize="13sp"
            tools:text="Duración: 7 días" />

        <TextView
            android:id="@+id/tvInstrucciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF3E0"
            android:padding="8dp"
            android:textColor="#E65100"
            android:textSize="13sp"
            android:textStyle="italic"
            tools:text="Nota: Tomar después de comer para no irritar el estómago." />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>