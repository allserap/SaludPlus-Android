<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/citas_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="300dp"
            android:layout_height="136dp"
            android:layout_marginTop="24dp"
            android:padding="20dp"
            android:src="@drawable/salu_plus_logo" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro de Usuario"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/citas_primary"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_tabs"
            android:padding="20dp"
            android:orientation="vertical"
            android:elevation="4dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear Cuenta"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/citas_primary"/>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete todos los campos para registrarse"
                android:textSize="13sp"
                android:textColor="@color/citas_primary"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Número de Afiliado ISSS -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Afiliado ISSS"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                android:layout_marginBottom="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAfiliadoR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/citas_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Campo: Nombre -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre"
                        android:textColorHint="@color/citas_primary"
                        app:hintTextColor="@color/citas_primary"
                        app:boxStrokeColor="@color/citas_primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombreR"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/citas_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Campo: Apellido -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Apellido"
                        android:textColorHint="@color/citas_primary"
                        app:hintTextColor="@color/citas_primary"
                        app:boxStrokeColor="@color/citas_primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etApellidoR"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/citas_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Campo: DUI -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="DUI"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDuiR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Fecha de Nacimiento -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha de Nacimiento"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:endIconTint="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Dropdown: Género -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Género"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                tools:ignore="MissingPrefix">

                <Spinner
                    android:id="@+id/spGeneroR"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Dropdown: Estado Familiar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Estado Familiar"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                tools:ignore="MissingPrefix">

                <Spinner
                    android:id="@+id/spEstadoFamiliarR"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Correo Electrónico -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo Electrónico"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreoR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Teléfono -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Teléfono"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelefonoR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etClaveR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Confirmar Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirmar Contraseña"
                android:layout_marginTop="12dp"
                android:textColorHint="@color/citas_primary"
                app:hintTextColor="@color/citas_primary"
                app:boxStrokeColor="@color/citas_primary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/citas_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmarClaveR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/citas_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_gravity="center"
                app:indicatorColor="@color/citas_primary"/>

            <!-- Botón de Registro como Material Filled Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCrearCuenta"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Crear Cuenta"
                android:textAllCaps="false"
                android:textColor="@color/citas_white"
                app:backgroundTint="@color/citas_primary"
                android:layout_marginTop="20dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvVolverALogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver al inicio de sesión"
                android:textColor="@color/citas_primary"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>