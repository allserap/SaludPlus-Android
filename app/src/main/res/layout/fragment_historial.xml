<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/citas_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="#ECECF3"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Título y Selector de Paciente -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar Paciente para Consulta"
                    android:textColor="@color/citas_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Buscador Único (ID emparejado con tu HistorialFragment) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilBuscarPaciente"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:hint="Buscar por Nombre o DUI"
                    app:boxStrokeColor="@color/citas_primary"
                    app:hintTextColor="@color/citas_primary">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteConsultar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:padding="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E0E0E0" />

                <!-- SECCIÓN 1: Identificación y Datos Generales (Solo Lectura) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Información del Paciente"
                    android:textColor="@color/citas_primary"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:hint="Nombre Completo"
                    app:boxBackgroundColor="#F1F3F4">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tvDisplayPacienteNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#5F6368" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Fila de DUI y Género -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:hint="DUI"
                        app:boxBackgroundColor="#F1F3F4">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tvDisplayDui"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:hint="Género"
                        app:boxBackgroundColor="#F1F3F4">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tvDisplayGenero"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Fila de Fecha de Nacimiento / Edad -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:enabled="false"
                    android:hint="Fecha de Nacimiento / Edad"
                    app:boxBackgroundColor="#F1F3F4">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tvDisplayEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E0E0E0" />

                <!-- SECCIÓN 2: Gestión Clínica del Médico (Campos Editables) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Registro Clínico de la Consulta"
                    android:textColor="@color/citas_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Campo Editable Alergias -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Alergias">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlergias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Editable Tipo Sanguíneo -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTipoSangre"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:hint="Tipo Sanguíneo"
                    app:boxStrokeColor="@color/citas_primary"
                    app:hintTextColor="@color/citas_primary">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerTipoSangre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="16dp"
                        android:textColor="#212121" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Editable Condiciones Cronicas -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Condiciones Cronicas">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCondicionesCronicas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Editable Medicamentos Recurrentes -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Medicamentos Recurrentes">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMedicamentosRecurrentes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Editable Notas Clínicas -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Notas Clínicas">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNotasClinicas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:lines="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Feedback Visual / Loader Interno de la Tarjeta -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="12dp"
                    android:visibility="gone" />

                <!-- Botonera de Acción -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:paddingTop="16dp">

                    <Button
                        android:id="@+id/btnCancelarFormulario"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="@color/citas_secondary"
                        android:text="Cancelar"
                        android:textAllCaps="false"
                        android:textColor="@color/citas_primary" />

                    <Button
                        android:id="@+id/btnGuardarExpediente"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="10dp"
                        android:backgroundTint="@color/citas_primary"
                        android:text="Guardar Consulta"
                        android:textAllCaps="false"
                        android:textColor="@color/citas_white" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>