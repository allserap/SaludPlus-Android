               Toast.makeText(this@PerfilActivity, \"Error de red\", Toast.LENGTH_LONG).show()\r\n            } finally {\r\n                overlayCarga.visibility = View.GONE\r\n            }\r\n        }\r\n    }\r\n\r\n    override fun onResume() {\r\n        super.onResume()\r\n        cargarPerfil()\r\n    }\r\n}
